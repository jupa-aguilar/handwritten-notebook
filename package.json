{
  "name": "handwritten-notebook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-only digital notebook for scanned handwritten pages",
  "author": "J. Aguilar <jaguilarviera@gmail.com>",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "app": "npm run build && electron .",
    "app:dev": "ELECTRON_START_URL=http://localhost:5173 electron .",
    "app:dist": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.jaguilar.my-notebook",
    "productName": "My Notebook",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "idb": "^8.0.0",
    "page-flip": "^2.0.7"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "vite": "^6.0.0"
  },
  "allowScripts": {
    "electron@43.0.0": true
  }
}
